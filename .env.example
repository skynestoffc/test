# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Payment API credentials (api.komputerz.site)
APIKEY=your_apikey_here
USERNAME_API=your_username_here
TOKEN_API=your_token_here

# Database path (default: ./data/db.json)
DB_PATH=./data/db.json

# Timezone for display (default: Asia/Jakarta)
TIMEZONE=Asia/Jakarta

# Optional: Telegram channel ID for testimoni posting
# CHANNEL_ID=@your_channel_or_-100xxxxxxxxx
